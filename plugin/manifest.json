{
  "name": "callsign",
  "version": "0.2.0",
  "description": "Unique per-session agent names + iMessage routing for Claude Code and Hermes.",
  "author": "heyfinal",
  "homepage": "https://github.com/heyfinal/callsign",
  "license": "MIT",
  "type": "claude-code-plugin",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PLUGIN_DIR}/../src/callsign/hooks/session_start.sh"
          }
        ]
      }
    ]
  },
  "skills": ["skills/callsign/SKILL.md"],
  "commands": ["commands/callsign.md"]
}
